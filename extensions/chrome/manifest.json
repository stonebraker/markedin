{
  "manifest_version": 3,
  "name": "markedin",
  "description": "Render .mi (markedin) files in the browser",
  "version": "0.2.0",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "include_globs": ["*.mi", "*.mi?*"],
      "js": ["lib/js-yaml.min.js", "lib/marked.min.js", "parse.js", "content.js"],
      "css": ["preview.css"],
      "run_at": "document_idle"
    }
  ]
}
